---
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="container footer-inner">
    <span>© {year} <a href="https://ranasalem.io" target="_blank" rel="noopener noreferrer" class="footer-link">Rana Salem</a></span>
    <span class="footer-divider">·</span>
    <a href="https://github.com/rtasalem/dev-suq" target="_blank" rel="noopener noreferrer" class="footer-link footer-github">
      <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
      </svg>
      GitHub
    </a>
  </div>
</footer>

<style>
  .footer {
    border-top: 1px solid var(--color-border);
    padding: 1.5rem 0;
    margin-top: auto;
  }

  .footer-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .footer-divider {
    opacity: 0.5;
  }

  .footer-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast), text-decoration-color var(--transition-fast);
    text-decoration: underline;
    text-decoration-color: transparent;
    text-underline-offset: 3px;
  }

  .footer-link:hover {
    color: var(--color-accent);
    text-decoration-color: var(--color-accent);
  }

  .footer-github {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    vertical-align: middle;
  }

  .footer-github svg {
    display: block;
    flex-shrink: 0;
  }
</style>
